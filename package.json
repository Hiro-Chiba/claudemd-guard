{
  "name": "claudemd-guard",
  "version": "2.0.0",
  "description": "AI-powered CLAUDE.md enforcer for Claude Code hooks",
  "author": "Hiro-Chiba",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hiro-Chiba/claudemd-guard.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "hooks",
    "claude-md",
    "ai-tools",
    "code-quality"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "claudemd-guard": "dist/cli/claudemd-guard.js"
  },
  "files": [
    "dist",
    "!dist/*.tsbuildinfo",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "checks": "npm run typecheck && npm run test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.72.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
